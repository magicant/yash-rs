{
  "image": "mcr.microsoft.com/devcontainers/rust:latest",
  "features": {
    "ghcr.io/wxw-matt/devcontainer-features/script_runner:0": {
      "script1": "install_cargo_binstall#https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh"
