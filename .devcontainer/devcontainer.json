{
  "image": "mcr.microsoft.com/devcontainers/rust:latest",
  "features": {
    "ghcr.io/wxw-matt/devcontainer-features/command_runner:latest": {
      "command1": "curl -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash",
      "command2": "cargo binstall --no-confirm cargo-semver-checks cargo-hack cargo-minimal-versions mdbook"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "streetsidesoftware.code-spell-checker",
        "tamasfe.even-better-toml"
      ]
    }
  }
}